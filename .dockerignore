# ------------------------------------------------------------
# Python bytecode and cache
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# ------------------------------------------------------------
# Python virtual environments
# ------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ------------------------------------------------------------
# Python tooling and test caches
# ------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# ------------------------------------------------------------
# Build and packaging artifacts
# ------------------------------------------------------------
build/
dist/
*.egg-info/
.eggs/

# ------------------------------------------------------------
# Git
# ------------------------------------------------------------
.git/
.gitignore
.gitattributes

# ------------------------------------------------------------
# IDE and editor files
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ------------------------------------------------------------
# Local environment/configuration
# ------------------------------------------------------------
.env
.env.*
*.local

# ------------------------------------------------------------
# Logs and temporary files
# ------------------------------------------------------------
*.log
*.tmp
*.temp
tmp/
temp/

# ------------------------------------------------------------
# Project documentation and development metadata
# ------------------------------------------------------------
README.md
LICENSE
docs/

# ------------------------------------------------------------
# Local GPX input/output data
# ------------------------------------------------------------
*.gpx

# ------------------------------------------------------------
# Shell/editor backup files
# ------------------------------------------------------------
*.bak
*.orig

# ------------------------------------------------------------
# Docker / Compose files not required inside the image
# ------------------------------------------------------------
Dockerfile*
docker-compose*.yml
docker-compose*.yaml
.dockerignore
